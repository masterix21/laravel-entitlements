{
    "name": "masterix21/laravel-entitlements",
    "description": "Simple and flexible entitlement management for Laravel applications, with support for plans, features, limits, and usage tracking.",
    "keywords": [
        "Luca Longo",
        "laravel",
        "laravel-entitlements"
    ],
    "homepage": "https://github.com/masterix21/laravel-entitlements",
    "license": "MIT",
    "authors": [
        {
            "name": "Luca Longo",
            "email": "l.longo@ambita.it",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-translatable": "^6.0",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "LucaLongo\\LaravelEntitlements\\": "src/",
            "LucaLongo\\LaravelEntitlements\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LucaLongo\\LaravelEntitlements\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LucaLongo\\LaravelEntitlements\\LaravelEntitlementsServiceProvider"
            ],
            "aliases": {
                "LaravelEntitlements": "LucaLongo\\LaravelEntitlements\\Facades\\LaravelEntitlements"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}